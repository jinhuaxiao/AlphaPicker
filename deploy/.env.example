# Copy to repo root as `.env` on the server (compose reads it). Do NOT commit.
POSTGRES_PASSWORD=change-me-strong-password

# Sorftime MCP (Amazon market data)
SORFTIME_MCP_URL=https://mcp.sorftime.com
SORFTIME_KEY=

# eBay Browse API (app OAuth from APPID/CERTID)
EBAY_APPID=
EBAY_CERTID=
EBAY_DEVID=
EBAY_AUTHTOKEN=

TIMEZONE=Asia/Shanghai
# Set false to skip the live-data seed on container start.
SEED_ON_START=true
